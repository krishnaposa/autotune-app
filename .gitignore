# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Auto-generated by Expo (regenerated locally / in CI)
expo-env.d.ts

# Native — keep source; ignore build artifacts & machine-local paths
# Android
android/app/build/
android/app/.cxx/
android/build/
android/.gradle/
android/.kotlin/
android/local.properties
android/captures/
android/**/*.iml
android/.idea/
android/.DS_Store

# iOS (when present)
ios/build/
ios/Pods/
ios/**/*.xcworkspace/xcuserdata/
ios/**/*.xcodeproj/xcuserdata/
ios/**/*.xcodeproj/project.xcworkspace/xcuserdata/
ios/DerivedData/
ios/.xcode.env.local

# Metro
.metro-health-check*

# debug / logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS
.DS_Store
*.pem

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# local env files (keep .env.example if you add one)
.env*.local
.env

# typescript
*.tsbuildinfo

# testing / coverage
coverage/

# misc
app-example

# keystores & signing (never commit real secrets)
*.jks
*.keystore
!debug.keystore
*.p8
*.p12
*.key
*.mobileprovision
