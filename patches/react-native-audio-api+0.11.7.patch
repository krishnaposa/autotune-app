+// Windows: `bash` in PATH often resolves to the WSL stub (System32\\bash.exe) and fails without a default distro.
+// Prefer Git for Windows bash when present so download-prebuilt-binaries.sh runs without WSL.
+def resolveBash() {
+  if (Os.isFamily(Os.FAMILY_WINDOWS)) {
+    def candidates = []
+    def pf = System.getenv("ProgramFiles")
+    def pf86 = System.getenv("ProgramFiles(x86)")
+    def local = System.getenv("LOCALAPPDATA")
+    if (pf != null) {
+      candidates.add(new File(pf, "Git/bin/bash.exe"))
+    }
+    if (pf86 != null) {
+      candidates.add(new File(pf86, "Git/bin/bash.exe"))
+    }
+    if (local != null) {
+      candidates.add(new File(local, "Programs/Git/bin/bash.exe"))
+    }
+    for (f in candidates) {
+      if (f.exists()) {
+        return f.absolutePath
+      }
+    }
+  }
+  return "bash"
+}
+
 task downloadPrebuiltBinaries(type: Exec) {
-  commandLine 'chmod', '+x', '../scripts/download-prebuilt-binaries.sh'
-  commandLine 'bash', '../scripts/download-prebuilt-binaries.sh'
+  commandLine resolveBash(), '../scripts/download-prebuilt-binaries.sh'
   args 'android', isFFmpegDisabled() ? 'skipffmpeg' : ''
 }
 
